# PlantSaathi Backend Environment Variables Example

SUPABASE_URL=your_supabase_project_url # Supabase project URL
SUPABASE_ANON_KEY=your_supabase_anon_key # Supabase anon/public API key

PLANT_API_BASE_URL=https://my-api.plantnet.org/v2/identify/all # PlantNet API endpoint
PLANT_API_KEY=your_plantnet_api_key # PlantNet API key

AI_API_KEY=your_openai_or_ai_provider_key # OpenAI or compatible AI API key

PORT=5000 # Port for backend server
NODE_ENV=development # Environment (development, production, test)
